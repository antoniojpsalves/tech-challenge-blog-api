generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  author    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
